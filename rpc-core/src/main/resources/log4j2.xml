<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{HH:mm:ss.SSS} %highlight{%-5level} [%t] %c{1} - %msg (%F:%L)%n"/>
        </Console>
    </Appenders>
    <Loggers>
        <!-- 屏蔽 ZooKeeper 日志 -->
        <Logger name="org.apache.zookeeper" level="WARN" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>
        <!-- 屏蔽 Curator 日志 -->
        <Logger name="org.apache.curator" level="WARN" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>
        <!-- 自己项目的日志保持 INFO 级别 -->
        <Logger name="com.tgu" level="INFO" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>
        <!-- Root 设为 WARN，屏蔽其他框架的 INFO 日志 -->
        <Root level="WARN">
            <AppenderRef ref="Console"/>
        </Root>
    </Loggers>
</Configuration>
